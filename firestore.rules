rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "dheeraj.rai90@gmail.com" || 
         request.auth.token.email == "komalbsc@gmail.com");
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    match /appointments/{appointmentId} {
      allow create: if true;
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /userProfiles/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow create: if isOwner(uid) && request.resource.data.loyaltyPoints == 0;
      allow update: if isAdmin() || (isOwner(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'updatedAt']));
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow create: if true;
      allow read: if isAdmin() || resource.data.approved == true;
      allow update, delete: if isAdmin();
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
